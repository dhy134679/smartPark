<view class="page data-v-dd383ca2"><view wx:if="{{a}}" class="card data-v-dd383ca2"><view class="title data-v-dd383ca2">个人信息</view><view class="data-v-dd383ca2">姓名：{{b}}</view><view class="data-v-dd383ca2">手机号：{{c}}</view><view class="data-v-dd383ca2">角色：{{d}}</view><button class="ghost data-v-dd383ca2" bindtap="{{e}}">退出登录</button></view><view wx:if="{{f}}" class="card data-v-dd383ca2"><view class="title data-v-dd383ca2">绑定车辆</view><view wx:for="{{g}}" wx:for-item="item" wx:key="e" class="vehicle-item data-v-dd383ca2"><view class="data-v-dd383ca2"><view class="plate data-v-dd383ca2">{{item.a}}</view><view class="data-v-dd383ca2">{{item.b}} / {{item.c}}</view></view><button class="data-v-dd383ca2" size="mini" type="warn" bindtap="{{item.d}}">解绑</button></view><view class="form data-v-dd383ca2"><input class="input data-v-dd383ca2" placeholder="车牌号" value="{{h}}" bindinput="{{i}}"/><input class="input data-v-dd383ca2" placeholder="品牌" value="{{j}}" bindinput="{{k}}"/><input class="input data-v-dd383ca2" placeholder="颜色" value="{{l}}" bindinput="{{m}}"/><label class="checkbox data-v-dd383ca2"><switch class="data-v-dd383ca2" checked="{{n}}" bindchange="{{o}}"/> 小区车辆 </label><button class="data-v-dd383ca2" type="primary" bindtap="{{p}}">添加车辆</button></view></view><view wx:if="{{q}}" class="card data-v-dd383ca2"><view class="title data-v-dd383ca2">我的车位与共享设置</view><view wx:if="{{r}}" class="empty data-v-dd383ca2">暂无名下车位</view><view wx:for="{{s}}" wx:for-item="spot" wx:key="k" class="spot-card data-v-dd383ca2"><view class="spot-header data-v-dd383ca2"><text class="plate data-v-dd383ca2">车位: {{spot.a}} ({{spot.b}}区)</text><switch class="data-v-dd383ca2" checked="{{spot.c}}" bindchange="{{spot.d}}" color="#2a82e4" style="transform:scale(0.8)"/></view><view wx:if="{{spot.e}}" class="share-opts data-v-dd383ca2"><view class="share-row data-v-dd383ca2"><text class="data-v-dd383ca2">共享开始时间:</text><input placeholder="YYYY-MM-DD HH:mm:ss" class="share-input data-v-dd383ca2" value="{{spot.f}}" bindinput="{{spot.g}}"/></view><view class="share-row data-v-dd383ca2"><text class="data-v-dd383ca2">共享结束时间:</text><input placeholder="YYYY-MM-DD HH:mm:ss" class="share-input data-v-dd383ca2" value="{{spot.h}}" bindinput="{{spot.i}}"/></view><button class="data-v-dd383ca2" size="mini" type="primary" bindtap="{{spot.j}}" style="margin-top:10rpx">保存时间设置</button></view></view></view><view wx:if="{{t}}" class="card data-v-dd383ca2"><view class="title data-v-dd383ca2">我的找平收益明细</view><view class="income-total data-v-dd383ca2">总计：￥{{v}}</view><view wx:for="{{w}}" wx:for-item="log" wx:key="d" class="income-row data-v-dd383ca2"><text class="data-v-dd383ca2">{{log.a}}</text><text class="data-v-dd383ca2">{{log.b}}</text><text class="income-plus data-v-dd383ca2">+{{log.c}}</text></view><view wx:if="{{x}}" class="empty data-v-dd383ca2"> 暂无收益记录 </view></view><view class="card quick-links data-v-dd383ca2"><button class="data-v-dd383ca2" bindtap="{{y}}">停车记录</button><button class="data-v-dd383ca2" bindtap="{{z}}">模拟出入</button></view></view>