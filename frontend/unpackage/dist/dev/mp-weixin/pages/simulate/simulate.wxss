
.page.data-v-19dd6a4c { padding: 24rpx; background: #f6f7fb; min-height: 100vh;
}
.card.data-v-19dd6a4c {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.06);
}
.card-header.data-v-19dd6a4c { margin-bottom: 24rpx;
}
.title.data-v-19dd6a4c {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

/* 步骤条 */
.step-bar.data-v-19dd6a4c {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}
.step.data-v-19dd6a4c {
  font-size: 22rpx;
  color: #ccc;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}
.step.active.data-v-19dd6a4c {
  color: #fff;
  background: linear-gradient(90deg, #2a82e4, #6a8bff);
}
.step-line.data-v-19dd6a4c {
  flex: 1;
  height: 4rpx;
  background: #eee;
  margin: 0 8rpx;
}
.step-line.active.data-v-19dd6a4c { background: #2a82e4;
}

/* 模式切换 */
.mode-switch.data-v-19dd6a4c {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

/* 上传区域 */
.upload-area.data-v-19dd6a4c {
  border: 3rpx dashed #d0d5dd;
  border-radius: 16rpx;
  height: 300rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
  overflow: hidden;
  background: #fafbfc;
}
.upload-placeholder.data-v-19dd6a4c {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}
.upload-icon.data-v-19dd6a4c { font-size: 60rpx; margin-bottom: 12rpx;
}
.preview-image.data-v-19dd6a4c { width: 100%; height: 100%;
}

/* 表单 */
.form-group.data-v-19dd6a4c { margin-bottom: 20rpx;
}
.input.data-v-19dd6a4c {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #f4f6fb;
  border-radius: 12rpx;
}

/* 识别结果 */
.recognize-result.data-v-19dd6a4c {
  background: #f0f7ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.result-header.data-v-19dd6a4c {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.result-plate.data-v-19dd6a4c {
  font-size: 36rpx;
  font-weight: bold;
  color: #2a82e4;
}
.confidence.data-v-19dd6a4c {
  font-size: 24rpx;
  color: #999;
}
.result-tag.data-v-19dd6a4c {
  display: inline-block;
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}
.result-tag.resident.data-v-19dd6a4c { background: #e8f5e9; color: #2e7d32;
}
.result-tag.visitor.data-v-19dd6a4c { background: #fff3e0; color: #ef6c00;
}

/* 按钮 */
.btn-primary.data-v-19dd6a4c {
  background: linear-gradient(90deg, #2a82e4, #6a8bff);
  color: #fff;
  border-radius: 12rpx;
  margin-top: 10rpx;
}
.btn-danger.data-v-19dd6a4c {
  background: linear-gradient(90deg, #ff5c5c, #ff8a65);
  color: #fff;
  border-radius: 12rpx;
  margin-top: 10rpx;
}
.btn-pay.data-v-19dd6a4c {
  background: linear-gradient(90deg, #30c594, #26a69a);
  color: #fff;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

/* 结果卡片 */
.result-card.data-v-19dd6a4c {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}
.result-card.success.data-v-19dd6a4c { background: #e8f5e9; border: 2rpx solid #a5d6a7;
}
.result-card.warning.data-v-19dd6a4c { background: #fff3e0; border: 2rpx solid #ffcc80;
}
.result-title.data-v-19dd6a4c { font-size: 30rpx; font-weight: bold; margin-bottom: 12rpx;
}
.result-row.data-v-19dd6a4c { font-size: 28rpx; margin-bottom: 8rpx; color: #555;
}
.bold.data-v-19dd6a4c { font-weight: bold; color: #333;
}
.fee-amount.data-v-19dd6a4c { font-size: 32rpx;
}
.text-green.data-v-19dd6a4c { color: #2e7d32;
}
.text-orange.data-v-19dd6a4c { color: #ef6c00;
}
