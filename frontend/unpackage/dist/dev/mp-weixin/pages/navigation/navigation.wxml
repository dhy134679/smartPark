" placeholder="颜色" value="{{item.G}}" bindinput="{{item.H}}"/><label class="switch-row data-v-b0045dab"><switch class="data-v-b0045dab" checked="{{item.I}}" bindchange="{{item.J}}"/><text class="data-v-b0045dab">小区车辆</text></label><button class="data-v-b0045dab" size="mini" type="primary" bindtap="{{item.K}}"> 添加车辆 </button></view></view></view></view></view><view wx:else class="data-v-b0045dab"><view class="map-container data-v-b0045dab"><view class="map-header data-v-b0045dab"><text class="title data-v-b0045dab">停车场平面图</text><view class="legend data-v-b0045dab"><view class="legend-item data-v-b0045dab"><view class="dot green data-v-b0045dab"></view>空闲</view><view class="legend-item data-v-b0045dab"><view class="dot red data-v-b0045dab"></view>占用</view><view class="legend-item data-v-b0045dab"><view class="dot blue data-v-b0045dab"></view>导航路线</view></view></view><canvas canvas-id="parkingMap" id="parkingMap" class="parking-canvas data-v-b0045dab" bindtap="{{p}}"></canvas></view><view class="card data-v-b0045dab"><view class="title data-v-b0045dab">选择目标车位</view><view class="zone-filter data-v-b0045dab"><button wx:for="{{q}}" wx:for-item="z" wx:key="b" class="data-v-b0045dab" size="mini" type="{{z.c}}" bindtap="{{z.d}}">{{z.a}}</button></view><scroll-view scroll-y class="spot-list data-v-b0045dab"><view wx:for="{{r}}" wx:for-item="spot" wx:key="c" class="{{['spot-item', 'data-v-b0045dab', spot.d && 'selected']}}" bindtap="{{spot.e}}"><text class="spot-name data-v-b0045dab">{{spot.a}}</text><text class="spot-zone data-v-b0045dab">{{spot.b}}区</text></view><view wx:if="{{s}}" class="empty data-v-b0045dab">暂无空闲车位</view></scroll-view></view><view wx:if="{{t}}" class="card data-v-b0045dab"><view class="title data-v-b0045dab">导航路线</view><view class="route-info data-v-b0045dab"><view class="info-item data-v-b0045dab"><text class="info-label data-v-b0045dab">起点</text><text class="info-value data-v-b0045dab">入口</text></view><view class="info-item data-v-b0045dab"><text class=